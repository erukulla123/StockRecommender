# ─── ValueScope Configuration ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The script reads these automatically via python-dotenv (optional)
# OR you can set them as system environment variables.

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-goes here

# ── SMTP (your email provider) ─────────────────────────────────────────────────
# Common providers:
#   Outlook / Office 365 : smtp.office365.com  port 587  TLS=true
#   Yahoo Mail           : smtp.mail.yahoo.com  port 587  TLS=true
#   Zoho Mail            : smtp.zoho.com        port 587  TLS=true
#   Custom / cPanel      : mail.yourdomain.com  port 587  TLS=true
#   AWS SES (SMTP)       : email-smtp.us-east-1.amazonaws.com  port 587  TLS=true
#   SendGrid (SMTP)      : smtp.sendgrid.net    port 587  TLS=true  user=apikey

SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password_here
SMTP_USE_TLS=true

# ── Email addresses ─────────────────────────────────────────────────────────────
EMAIL_FROM=your@email.com
EMAIL_TO=youremail@email.com

# ── Screener settings ──────────────────────────────────────────────────────────
MAX_PE=20
SECTOR=any
# Options: any | technology | healthcare | financials | energy | consumer | industrials | utilities

MARKET_CAP=any
# Options: any | large | mid | small
